      <data key="d0">ec16acd4-2aad-449a-a5ee-14d41dec3d48</data>
      <data key="d1">13</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"Master data output is serial data to the external slave, MSB first, shifted on the falling clock edge."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
