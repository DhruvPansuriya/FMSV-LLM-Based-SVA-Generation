      <data key="d0">916bff72-5624-4d2e-9d96-8e931588919c</data>
      <data key="d1">16</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"Interrupt request is asserted when transmission complete or parity error is detected."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
