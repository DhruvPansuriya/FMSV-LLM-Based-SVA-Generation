    </node>
    <node id="&quot;DATA VALID&quot;">
      <data key="d0">6ef91503-7105-43e7-ad8f-7b68d4c18e97</data>
      <data key="d1">20</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"Data valid is asserted for one cycle when a new received byte is available in the receive buffer."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
