      <data key="d0">aff96849-fcf0-45d9-b59c-68b2516b5632</data>
      <data key="d1">36</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"The transfer acknowledge signal is asserted high by SDC to complete APB transactions."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
