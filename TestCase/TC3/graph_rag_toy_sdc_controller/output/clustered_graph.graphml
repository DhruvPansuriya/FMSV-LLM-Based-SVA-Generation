      <data key="d0">4d05e099-5b70-4e62-b40e-8a223eab2d01</data>
      <data key="d1">33</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"The register address signal selects the target register for APB transfers."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">1</data>
