    <node id="&quot;TRANSMISSION COMPLETE&quot;">
      <data key="d0">2e6f3fd9-dbff-405f-9644-cf0a55e270bf</data>
      <data key="d1">17</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"Transmission complete is pulsed for one clock cycle when the last bit of a frame has been shifted out."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
