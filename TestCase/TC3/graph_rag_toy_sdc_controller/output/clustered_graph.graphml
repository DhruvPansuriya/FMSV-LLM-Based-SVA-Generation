      <data key="d0">172ecce6-9869-4932-8dc0-e180998b952d</data>
      <data key="d1">19</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"FIFO empty status is asserted when the transmit buffer has no pending data and is ready for a new frame."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
