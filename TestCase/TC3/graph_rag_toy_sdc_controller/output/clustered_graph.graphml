      <data key="d1">32</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"The write enable signal is used to indicate write operation, generating an active-low write strobe when asserted."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">1</data>
