    <node id="&quot;RECEIVE BUFFER FULL&quot;">
      <data key="d0">5e75873f-886e-4eff-91dd-13929acdd40a</data>
      <data key="d1">22</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"Receive buffer full is an active-low flag, deasserted when the receive buffer cannot accept additional bytes."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">1</data>
    </node>
    <node id="&quot;FLOW CONTROL ENABLE&quot;">
      <data key="d0">722157c0-b8b0-4e8c-9863-36b9e41a1b6a</data>
      <data key="d1">23</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"Flow control enable activates CTS/RTS-style handshaking when set in the control register."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
