    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;INTERRUPT REQUEST&quot;">
      <data key="d7">5e63c5f7-d982-416a-b4cd-02a235e071eb</data>
      <data key="d8">15</data>
      <data key="d9">"Interrupt request is asserted when transmission complete or parity error is detected, which is enabled using the SDC."</data>
      <data key="d10">8.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;TRANSMISSION COMPLETE&quot;">
      <data key="d7">88f0810a-93a5-469f-8f14-bbc98b858598</data>
      <data key="d8">16</data>
      <data key="d9">"Transmission complete is pulsed for one clock cycle when the last bit of a frame has been shifted out, which is enabled using the SDC."</data>
      <data key="d10">8.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;TRANSMIT ACKNOWLEDGE&quot;">
      <data key="d7">07692a83-4e71-4f63-b721-ba6bd93ea734</data>
      <data key="d8">17</data>
      <data key="d9">"Transmit acknowledge is set when the remote slave confirms receipt of the last transmitted byte, which is enabled using the SDC."</data>
      <data key="d10">8.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;FIFO EMPTY STATUS&quot;">
      <data key="d7">edcd1b7f-a421-4aec-a2b0-d39cefa7c799</data>
      <data key="d8">18</data>
      <data key="d9">"FIFO empty status is asserted when the transmit buffer has no pending data and is ready for a new frame, which is enabled using the SDC."</data>
      <data key="d10">7.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;DATA VALID&quot;">
      <data key="d7">bc354e53-00a7-4811-b084-b92de0853801</data>
      <data key="d8">19</data>
      <data key="d9">"Data valid is asserted for one cycle when a new received byte is available in the receive buffer, which is enabled using the SDC."</data>
      <data key="d10">7.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;PARITY ERROR FLAG&quot;">
      <data key="d7">2a98164c-f090-4c64-93e3-31e85dd6ea53</data>
      <data key="d8">20</data>
      <data key="d9">"Parity error flag is set and held when a parity mismatch is detected on the received byte, which is enabled using the SDC."</data>
      <data key="d10">8.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;RECEIVE BUFFER FULL&quot;">
      <data key="d7">4f632deb-3608-4087-9abc-73f7c9e69106</data>
      <data key="d8">21</data>
      <data key="d9">"Receive buffer full is an active-low flag, deasserted when the receive buffer cannot accept additional bytes, which is enabled using the SDC."</data>
      <data key="d10">1.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;SPI&quot;">
      <data key="d7">4bfb3f2a-cb39-4b69-83d7-bd038b98cfcc</data>
      <data key="d8">22</data>
      <data key="d9">"The SDC uses the SPI protocol for communication with external slave devices, supporting configurable baud rates and hardware flow control."</data>
      <data key="d10">9.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;CONTROL REGISTER&quot;">
      <data key="d7">158f435d-d27f-4b9d-bcfe-ed9430697807</data>
      <data key="d8">23</data>
      <data key="d9">"The control register is part of the SDC, containing mode and enable bits for the APB interface and serial interface."</data>
      <data key="d10">8.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;BAUD RATE DIVISOR&quot;">
      <data key="d7">1bb206a8-0ea1-40f8-a01d-b25c61623a24</data>
      <data key="d8">24</data>
      <data key="d9">"The baud rate divisor register is part of the SDC, setting the system clock divisor for SPI clock generation."</data>
      <data key="d10">8.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;STATUS REGISTER&quot;">
      <data key="d7">b33f00ac-8041-492c-b509-a4158ac8dbe6</data>
      <data key="d8">25</data>
      <data key="d9">"The status register is part of the SDC, containing all status flags, including receive buffer full, FIFO empty status, transmit acknowledge, and more."</data>
      <data key="d10">8.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;SYSTEM CLOCK SIGNAL&quot;">
      <data key="d7">eb082eb0-35ee-4d8a-ba72-ff3fc4e29f69</data>
      <data key="d8">26</data>
      <data key="d9">"The system clock signal is used by the SDC for all synchronous logic operations."</data>
      <data key="d10">9.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;SYSTEM RESET SIGNAL&quot;">
      <data key="d7">76aca763-7263-46ff-a08e-81ef99b2be60</data>
      <data key="d8">27</data>
      <data key="d9">"The system reset signal clears all registers and deasserts the chip select when asserted to the SDC."</data>
      <data key="d10">9.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;INTERRUPT REQUEST SIGNAL&quot;">
      <data key="d7">27a0ed76-1162-4918-8ad4-c96f7fef76f1</data>
      <data key="d8">39</data>
      <data key="d9">"The interrupt request signal is asserted when transmission complete or parity error is detected, and is part of the SDC."</data>
      <data key="d10">8.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;TRANSMISSION COMPLETE SIGNAL&quot;">
      <data key="d7">dbb0fa1a-1e80-4317-8804-e830fbc5af25</data>
      <data key="d8">40</data>
      <data key="d9">"The transmission complete signal is pulsed for one clock cycle when the last bit of a frame has been shifted out, and is part of the SDC."</data>
      <data key="d10">8.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;TRANSMIT ACKNOWLEDGE SIGNAL&quot;">
      <data key="d7">28dd8d91-4b79-4c20-8c36-e310c505870b</data>
      <data key="d8">41</data>
      <data key="d9">"The transmit acknowledge signal is set when the remote slave confirms receipt of the last transmitted byte, and is part of the SDC."</data>
      <data key="d10">8.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;FIFO EMPTY STATUS SIGNAL&quot;">
      <data key="d7">ac82034a-0c1c-4671-9cad-70f6e29e59e4</data>
      <data key="d8">42</data>
      <data key="d9">"The FIFO empty status signal is asserted when the transmit buffer has no pending data and is ready for a new frame, and is part of the SDC."</data>
      <data key="d10">7.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;DATA VALID SIGNAL&quot;">
      <data key="d7">04ad5aec-573b-4254-bf54-f6c120c226c1</data>
      <data key="d8">43</data>
      <data key="d9">"The data valid signal is asserted for one cycle when a new received byte is available in the receive buffer, and is part of the SDC."</data>
      <data key="d10">7.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;PARITY ERROR FLAG SIGNAL&quot;">
      <data key="d7">8029b3d4-751c-41f2-bca3-ed52fd658201</data>
      <data key="d8">44</data>
      <data key="d9">"The parity error flag signal is set and held when a parity mismatch is detected on the received byte, and is part of the SDC."</data>
      <data key="d10">8.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;RECEIVE BUFFER FULL SIGNAL&quot;">
      <data key="d7">f368d0e4-6566-4a7e-ad1a-d18f6af0a6c8</data>
      <data key="d8">45</data>
      <data key="d9">"The receive buffer full signal is an active-low flag, deasserted when the receive buffer cannot accept additional bytes, and is part of the SDC."</data>
      <data key="d10">8.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;FLOW CONTROL ENABLE SIGNAL&quot;">
      <data key="d7">9fffaa0b-38ae-4738-8ad7-bebf57341fa2</data>
      <data key="d8">46</data>
      <data key="d9">"The flow control enable signal activates CTS/RTS-style handshaking when set in the control register, and is part of the SDC."</data>
      <data key="d10">7.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;PARAMETER&quot;">
      <data key="d7">00b4f05b-742e-4f5c-afa1-91010dae51f7</data>
      <data key="d8">47</data>
      <data key="d9">"The SDC has several parameters that can be configured, including the baud rate divisor and flow control enable."</data>
      <data key="d10">8.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;BUS&quot;">
      <data key="d7">380295f8-1e75-40ba-b1ed-a8f5c5b58a09</data>
      <data key="d8">48</data>
      <data key="d9">"The SDC uses the APB bus for communication with the host processor."</data>
      <data key="d10">8.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;CLOCK&quot;">
      <data key="d7">6b5d4f89-c0da-43f8-a297-e7bfd7ee9860</data>
      <data key="d8">49</data>
      <data key="d9">"The SDC uses a system clock signal for all synchronous logic operations."</data>
      <data key="d10">9.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;RESET&quot;">
      <data key="d7">e921fedf-1716-49f4-8074-20a3e71fc7b6</data>
      <data key="d8">50</data>
      <data key="d9">"The SDC has a system reset signal that clears all registers and deasserts the chip select when asserted."</data>
      <data key="d10">9.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;INTERFACE&quot;">
      <data key="d7">43363f75-9836-41bd-aab4-4d956f98cd80</data>
      <data key="d8">51</data>
      <data key="d9">"The SDC has two interfaces: APB slave interface and SPI interface."</data>
      <data key="d10">8.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;PROTOCOL&quot;">
      <data key="d7">bf109ab3-b977-4c18-89e3-82845aa1f732</data>
      <data key="d8">52</data>
      <data key="d9">"The SDC uses two protocols: APB and SPI."</data>
      <data key="d10">8.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SERIAL DATA CONTROLLER (SDC)&quot;" target="&quot;SIGNAL&quot;">
      <data key="d7">a54e866a-9b1b-45a9-8e5b-b6e0968c2565</data>
      <data key="d8">53</data>
      <data key="d9">"The SDC has several signals, including the system clock signal, system reset signal, and interrupt request signal."</data>
      <data key="d10">8.0</data>
      <data key="d11">33</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;APB SLAVE INTERFACE&quot;" target="&quot;PERIPHERAL SELECT&quot;">
      <data key="d7">3d468779-3dc3-4e89-a5b5-e3a584976be5</data>
      <data key="d8">4</data>
      <data key="d9">"The peripheral select signal is used to select the SDC as an APB slave, allowing host processor configuration and communication with external devices."</data>
      <data key="d10">8.0</data>
      <data key="d11">17</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;APB SLAVE INTERFACE&quot;" target="&quot;TRANSFER ENABLE&quot;">
      <data key="d7">c8abe7d7-24ba-434a-88ef-324c18fbf617</data>
      <data key="d8">5</data>
      <data key="d9">"Transfer enable marks the second cycle of an APB transfer, which is enabled using the SDC's APB slave interface."</data>
      <data key="d10">7.0</data>
      <data key="d11">17</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;APB SLAVE INTERFACE&quot;" target="&quot;WRITE ENABLE&quot;">
      <data key="d7">02a9a1e4-e5c5-40bd-bd51-e1ae1171e128</data>
      <data key="d8">6</data>
      <data key="d9">"Write enable is used to indicate write operation to the SDC, generating an active-low write strobe when asserted."</data>
      <data key="d10">7.0</data>
      <data key="d11">17</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;APB SLAVE INTERFACE&quot;" target="&quot;REGISTER ADDRESS&quot;">
      <data key="d7">e1a131b2-187b-4a72-bc90-b890ad006b92</data>
      <data key="d8">7</data>
      <data key="d9">"Register address selects the target register for APB transfers in the SDC, which is enabled using the SDC's APB slave interface."</data>
      <data key="d10">7.0</data>
      <data key="d11">17</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;APB SLAVE INTERFACE&quot;" target="&quot;WRITE DATA BUS&quot;">
      <data key="d7">71fb571f-ed62-4970-ad5f-999ea52c44bd</data>
      <data key="d8">8</data>
      <data key="d9">"Write data bus carries 32-bit data from the master to SDC during writes, which is enabled using the SDC's APB slave interface."</data>
      <data key="d10">7.0</data>
      <data key="d11">17</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;APB SLAVE INTERFACE&quot;" target="&quot;READ DATA BUS&quot;">
      <data key="d7">2cfa5be5-0a13-4a0c-8e65-9ee5dc19b80f</data>
      <data key="d8">9</data>
      <data key="d9">"Read data bus carries 32-bit data from SDC to the master during reads, which is enabled using the SDC's APB slave interface."</data>
      <data key="d10">7.0</data>
      <data key="d11">17</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;APB SLAVE INTERFACE&quot;" target="&quot;TRANSFER ACKNOWLEDGE&quot;">
      <data key="d7">07a38a40-0212-4e07-9235-af45383fd334</data>
      <data key="d8">10</data>
      <data key="d9">"Transfer acknowledge is asserted high by SDC to complete APB transactions, which is enabled using the SDC's APB slave interface."</data>
      <data key="d10">8.0</data>
      <data key="d11">17</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;APB SLAVE INTERFACE&quot;" target="&quot;PERIPHERAL SELECT SIGNAL&quot;">
      <data key="d7">2961e50a-0836-4986-83b8-93d12d23fcec</data>
      <data key="d8">28</data>
      <data key="d9">"The peripheral select signal is used to select the SDC as an APB slave."</data>
      <data key="d10">8.0</data>
      <data key="d11">17</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;APB SLAVE INTERFACE&quot;" target="&quot;TRANSFER ENABLE SIGNAL&quot;">
      <data key="d7">52802808-9da4-4bd1-a779-83dc70fb2f62</data>
      <data key="d8">29</data>
      <data key="d9">"The transfer enable signal marks the second cycle of an APB transfer."</data>
      <data key="d10">7.0</data>
      <data key="d11">17</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;APB SLAVE INTERFACE&quot;" target="&quot;WRITE ENABLE SIGNAL&quot;">
      <data key="d7">1d588a57-b84f-4556-8fd6-037e24b1c6f1</data>
      <data key="d8">30</data>
      <data key="d9">"The write enable signal is used to indicate write operation to the SDC, generating an active-low write strobe when asserted."</data>
      <data key="d10">7.0</data>
      <data key="d11">17</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;APB SLAVE INTERFACE&quot;" target="&quot;REGISTER ADDRESS SIGNAL&quot;">
      <data key="d7">266cc1a6-3101-4749-9259-804dac758d2a</data>
      <data key="d8">31</data>
      <data key="d9">"The register address signal selects the target register for APB transfers."</data>
      <data key="d10">7.0</data>
      <data key="d11">17</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;APB SLAVE INTERFACE&quot;" target="&quot;WRITE DATA BUS SIGNAL&quot;">
      <data key="d7">d11bbcf3-189a-4984-ae3f-0cda3ccbd67e</data>
      <data key="d8">32</data>
      <data key="d9">"The write data bus signal carries 32-bit data from the master to SDC during writes."</data>
      <data key="d10">7.0</data>
      <data key="d11">17</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;APB SLAVE INTERFACE&quot;" target="&quot;READ DATA BUS SIGNAL&quot;">
      <data key="d7">02afade8-ae50-4158-a591-330f9060b4cf</data>
      <data key="d8">33</data>
      <data key="d9">"The read data bus signal carries 32-bit data from SDC to the master during reads."</data>
      <data key="d10">7.0</data>
      <data key="d11">17</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;APB SLAVE INTERFACE&quot;" target="&quot;TRANSFER ACKNOWLEDGE SIGNAL&quot;">
      <data key="d7">ee14593c-82b8-4f4c-9a56-98c647716f55</data>
      <data key="d8">34</data>
      <data key="d9">"The transfer acknowledge signal is asserted high by SDC to complete APB transactions."</data>
      <data key="d10">8.0</data>
      <data key="d11">17</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;APB SLAVE INTERFACE&quot;" target="&quot;SPI INTERFACE&quot;">
      <data key="d7">3b58a669-b26d-4092-9dcd-6f414ecdfaf8</data>
      <data key="d8">54</data>
      <data key="d9">"The APB slave interface and SPI interface are both part of the SDC, and are used for communication with the host processor and external slave devices, respectively."</data>
      <data key="d10">7.0</data>
      <data key="d11">26</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SPI INTERFACE&quot;" target="&quot;SERIAL CLOCK&quot;">
      <data key="d7">a38b5703-4fba-450e-8e4c-6e31f60d3bfa</data>
      <data key="d8">11</data>
      <data key="d9">"Serial clock is generated by SDC, with frequency set by the baud rate divisor, which is used in the SPI interface for communication with external slave devices."</data>
      <data key="d10">8.0</data>
      <data key="d11">11</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SPI INTERFACE&quot;" target="&quot;MASTER DATA OUTPUT&quot;">
      <data key="d7">f473dc30-28cc-40e1-88c9-643df138f604</data>
      <data key="d8">12</data>
      <data key="d9">"Master data output is serial data to the external slave, MSB first, shifted on the falling clock edge, which is used in the SPI interface for communication with external slave devices."</data>
      <data key="d10">8.0</data>
      <data key="d11">11</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SPI INTERFACE&quot;" target="&quot;MASTER DATA INPUT&quot;">
      <data key="d7">e7cdd713-8dbf-4ba7-8813-e1cd5597269f</data>
      <data key="d8">13</data>
      <data key="d9">"Master data input is serial data from the external slave, sampled on the rising clock edge, which is used in the SPI interface for communication with external slave devices."</data>
      <data key="d10">8.0</data>
      <data key="d11">11</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SPI INTERFACE&quot;" target="&quot;CHIP SELECT&quot;">
      <data key="d7">d9857aef-fc83-47d9-a015-914dbaf88a00</data>
      <data key="d8">14</data>
      <data key="d9">"Chip select is an active-low output driven low at the start of a frame to address the external slave, which is used in the SPI interface for communication with external slave devices."</data>
      <data key="d10">7.0</data>
      <data key="d11">11</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SPI INTERFACE&quot;" target="&quot;SERIAL CLOCK SIGNAL&quot;">
      <data key="d7">472f032a-20a9-4b93-a1f5-725b51104c01</data>
      <data key="d8">35</data>
      <data key="d9">"The serial clock signal is generated by SDC, with frequency set by the baud rate divisor, and is used in the SPI interface for communication with external slave devices."</data>
      <data key="d10">8.0</data>
      <data key="d11">11</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SPI INTERFACE&quot;" target="&quot;MASTER DATA OUTPUT SIGNAL&quot;">
      <data key="d7">2100f54b-950c-4086-b3de-e09db3a83673</data>
      <data key="d8">36</data>
      <data key="d9">"The master data output signal is serial data to the external slave, MSB first, shifted on the falling clock edge, and is used in the SPI interface for communication with external slave devices."</data>
      <data key="d10">8.0</data>
      <data key="d11">11</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SPI INTERFACE&quot;" target="&quot;MASTER DATA INPUT SIGNAL&quot;">
      <data key="d7">f3d25402-abdc-407e-952c-e1b140ed8bb1</data>
      <data key="d8">37</data>
      <data key="d9">"The master data input signal is serial data from the external slave, sampled on the rising clock edge, and is used in the SPI interface for communication with external slave devices."</data>
      <data key="d10">8.0</data>
      <data key="d11">11</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
    <edge source="&quot;SPI INTERFACE&quot;" target="&quot;CHIP SELECT SIGNAL&quot;">
      <data key="d7">33568384-61e4-46b0-9c6d-98ac0928cd6e</data>
      <data key="d8">38</data>
      <data key="d9">"The chip select signal is an active-low output driven low at the start of a frame to address the external slave, and is used in the SPI interface for communication with external slave devices."</data>
      <data key="d10">7.0</data>
      <data key="d11">11</data>
      <data key="d12">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
    </edge>
