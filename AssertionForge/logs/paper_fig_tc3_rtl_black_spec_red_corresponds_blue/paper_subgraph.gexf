    <nodes>
      <node id="67ef01a4-cdeb-43d9-9881-d9786262c752" label="&quot;SERIAL DATA CONTROLLER (SDC)&quot;">
        <attvalues>
          <attvalue for="0" value="0" />
          <attvalue for="1" value="&quot;MODULE&quot;" />
          <attvalue for="2" value="&quot;The Serial Data Controller (SDC) is a module that provides an APB slave interface and a SPI-compatible serial interface for communication with external slave devices.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="12" />
        </attvalues>
      </node>
      <node id="aff1ceb1-8c84-4cac-8ee9-913ca5704dce" label="&quot;APB INTERFACE&quot;">
        <attvalues>
          <attvalue for="0" value="1" />
          <attvalue for="1" value="&quot;INTERFACE&quot;" />
          <attvalue for="2" value="&quot;The APB interface is used for host processor configuration.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="10" />
        </attvalues>
      </node>
      <node id="338983ca-f2c7-426d-bb85-97e213320911" label="&quot;SPI INTERFACE&quot;">
        <attvalues>
          <attvalue for="0" value="2" />
          <attvalue for="1" value="&quot;INTERFACE&quot;" />
          <attvalue for="2" value="&quot;The SPI interface is used for communication with external slave devices.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="7" />
        </attvalues>
      </node>
      <node id="3dec1e15-cb67-4598-8d6d-f03795410a43" label="&quot;SYSTEM CLOCK&quot;">
        <attvalues>
          <attvalue for="0" value="3" />
          <attvalue for="1" value="&quot;CLOCK&quot;" />
          <attvalue for="2" value="&quot;The system clock is the primary clock input for the SDC.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="3" />
        </attvalues>
      </node>
      <node id="c9f8655b-4f06-4df0-aba0-99edbe58b41b" label="&quot;SYSTEM RESET&quot;">
        <attvalues>
          <attvalue for="0" value="4" />
          <attvalue for="1" value="&quot;RESET&quot;" />
          <attvalue for="2" value="&quot;The system reset is an asynchronous, active-low signal that clears all registers and deasserts the chip select when asserted low.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f'&#10; '1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="2" />
          <attvalue for="5" value="4" />
        </attvalues>
      </node>
      <node id="3bdbe4f2-9be5-45ec-94ed-6abc1932fc49" label="&quot;PERIPHERAL SELECT&quot;">
        <attvalues>
          <attvalue for="0" value="5" />
          <attvalue for="1" value="&quot;SIGNAL&quot;" />
          <attvalue for="2" value="&quot;The peripheral select signal is driven high by the APB master to select the SDC.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="1" />
        </attvalues>
      </node>
      <node id="deca1e63-ff7e-49fd-963d-58f90469b9b4" label="&quot;TRANSFER ENABLE&quot;">
        <attvalues>
          <attvalue for="0" value="6" />
          <attvalue for="1" value="&quot;SIGNAL&quot;" />
          <attvalue for="2" value="&quot;The transfer enable signal marks the second cycle of an APB transfer.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="1" />
        </attvalues>
      </node>
      <node id="f75dd1cc-ff0e-4721-900e-92d32f72b38e" label="&quot;WRITE ENABLE&quot;">
        <attvalues>
          <attvalue for="0" value="7" />
          <attvalue for="1" value="&quot;SIGNAL&quot;" />
          <attvalue for="2" value="&quot;The write enable signal is high for write and low for read operations.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="1" />
        </attvalues>
      </node>
      <node id="1b4da10d-adcb-4197-840b-0cf9b6332e01" label="&quot;REGISTER ADDRESS&quot;">
        <attvalues>
          <attvalue for="0" value="8" />
          <attvalue for="1" value="&quot;SIGNAL&quot;" />
          <attvalue for="2" value="&quot;The register address signal is an 8-bit address bus that selects the target register.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="1" />
        </attvalues>
      </node>
      <node id="d986e63c-7021-40fd-a242-83f70dd1a3f5" label="&quot;WRITE DATA BUS&quot;">
        <attvalues>
          <attvalue for="0" value="9" />
          <attvalue for="1" value="&quot;SIGNAL&quot;" />
          <attvalue for="2" value="&quot;The write data bus is a 32-bit data bus from the master to the SDC during writes.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="1" />
        </attvalues>
      </node>
      <node id="fa4b8e9c-7465-4949-95b9-bfdea70ba1e3" label="&quot;READ DATA BUS&quot;">
        <attvalues>
          <attvalue for="0" value="10" />
          <attvalue for="1" value="&quot;SIGNAL&quot;" />
          <attvalue for="2" value="&quot;The read data bus is a 32-bit data bus from the SDC to the master during reads.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="1" />
        </attvalues>
      </node>
      <node id="016bd329-b71a-429e-b108-dba38fbd2e63" label="&quot;TRANSFER ACKNOWLEDGE&quot;">
        <attvalues>
          <attvalue for="0" value="11" />
          <attvalue for="1" value="&quot;SIGNAL&quot;" />
          <attvalue for="2" value="&quot;The transfer acknowledge signal is asserted high by the SDC to complete the APB transaction.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="1" />
        </attvalues>
      </node>
      <node id="ec4bd048-e455-44f5-8d58-3366a51e0184" label="&quot;SERIAL CLOCK&quot;">
        <attvalues>
          <attvalue for="0" value="12" />
          <attvalue for="1" value="&quot;SIGNAL&quot;" />
          <attvalue for="2" value="&quot;The serial clock signal is generated by the SDC and its frequency is set by the baud rate divisor.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="1" />
        </attvalues>
      </node>
      <node id="93f733c4-ec40-43f9-a711-c0d68dd4b5a4" label="&quot;MASTER DATA OUTPUT&quot;">
        <attvalues>
          <attvalue for="0" value="13" />
          <attvalue for="1" value="&quot;SIGNAL&quot;" />
          <attvalue for="2" value="&quot;The master data output signal is the serial data output from the SDC to the external slave.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="1" />
        </attvalues>
      </node>
      <node id="e2e2e127-c015-449e-b082-06e4d63dff2b" label="&quot;MASTER DATA INPUT&quot;">
        <attvalues>
          <attvalue for="0" value="14" />
          <attvalue for="1" value="&quot;SIGNAL&quot;" />
          <attvalue for="2" value="&quot;The master data input signal is the serial data input from the external slave to the SDC.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="1" />
        </attvalues>
      </node>
      <node id="6ed3577e-de16-41d1-b4b9-cfb109d77f1d" label="&quot;CHIP SELECT&quot;">
        <attvalues>
          <attvalue for="0" value="15" />
          <attvalue for="1" value="&quot;SIGNAL&quot;" />
          <attvalue for="2" value="&quot;The chip select signal is an active-low output that is driven low at the start of a frame to address the external slave.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="1" />
        </attvalues>
      </node>
      <node id="b0381e93-039c-4905-a43b-f6c262576f0f" label="&quot;INTERRUPT REQUEST&quot;">
        <attvalues>
          <attvalue for="0" value="16" />
          <attvalue for="1" value="&quot;SIGNAL&quot;" />
          <attvalue for="2" value="&quot;The interrupt request signal is asserted when transmission is complete or a parity error is detected.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="1" />
        </attvalues>
      </node>
      <node id="2ee5ee69-6b74-49e6-ae6c-a7a9f9f60c58" label="&quot;TRANSMISSION COMPLETE&quot;">
        <attvalues>
          <attvalue for="0" value="17" />
          <attvalue for="1" value="&quot;SIGNAL&quot;" />
          <attvalue for="2" value="&quot;The transmission complete signal is pulsed for one clock cycle when the last bit of a frame has been shifted out.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="0" />
        </attvalues>
      </node>
      <node id="d2df1a40-d564-4136-864d-f2525789c7a8" label="&quot;TRANSMIT ACKNOWLEDGE&quot;">
        <attvalues>
          <attvalue for="0" value="18" />
          <attvalue for="1" value="&quot;SIGNAL&quot;" />
          <attvalue for="2" value="&quot;The transmit acknowledge signal is set when the remote slave confirms receipt of the last transmitted byte.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="0" />
        </attvalues>
      </node>
      <node id="74edf1e8-b0bf-40fa-ba1d-18fe7eac7ba4" label="&quot;FIFO EMPTY STATUS&quot;">
        <attvalues>
          <attvalue for="0" value="19" />
          <attvalue for="1" value="&quot;SIGNAL&quot;" />
          <attvalue for="2" value="&quot;The FIFO empty status signal is asserted when the transmit buffer has no pending data and is ready for a new frame.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="0" />
        </attvalues>
      </node>
      <node id="609deb5d-01bc-4a09-8753-45eeaedaa027" label="&quot;DATA VALID&quot;">
        <attvalues>
          <attvalue for="0" value="20" />
          <attvalue for="1" value="&quot;SIGNAL&quot;" />
          <attvalue for="2" value="&quot;The data valid signal is asserted for one cycle when a new received byte is available in the receive buffer.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="0" />
        </attvalues>
      </node>
      <node id="86202cdb-9133-4430-9364-7d4c07e7c35e" label="&quot;PARITY ERROR FLAG&quot;">
        <attvalues>
          <attvalue for="0" value="21" />
          <attvalue for="1" value="&quot;SIGNAL&quot;" />
          <attvalue for="2" value="&quot;The parity error flag signal is set and held when a parity mismatch is detected on the received byte.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="0" />
        </attvalues>
      </node>
      <node id="621d9ab0-6a1a-4221-8012-c33898cec5f1" label="&quot;RECEIVE BUFFER FULL&quot;">
        <attvalues>
          <attvalue for="0" value="22" />
          <attvalue for="1" value="&quot;SIGNAL&quot;" />
          <attvalue for="2" value="&quot;The receive buffer full signal is an active-low flag that is deasserted when the receive buffer cannot accept additional bytes.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="0" />
        </attvalues>
      </node>
      <node id="34b56916-3b24-4035-9a21-d04aef2f9117" label="&quot;FLOW CONTROL ENABLE&quot;">
        <attvalues>
          <attvalue for="0" value="23" />
          <attvalue for="1" value="&quot;SIGNAL&quot;" />
          <attvalue for="2" value="&quot;The flow control enable signal is set in the control register to activate CTS/RTS-style handshaking.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="0" />
        </attvalues>
      </node>
      <node id="bf744a66-b0b0-47c3-88eb-df537ac6c421" label="&quot;CONTROL REGISTER&quot;">
        <attvalues>
          <attvalue for="0" value="24" />
          <attvalue for="1" value="&quot;PARAMETER&quot;" />
          <attvalue for="2" value="&quot;The control register is a register that contains mode and enable bits.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="5" />
        </attvalues>
      </node>
      <node id="d4bfcc4c-1e24-4d9f-9032-31165a750cd9" label="&quot;BAUD RATE DIVISOR&quot;">
        <attvalues>
          <attvalue for="0" value="25" />
          <attvalue for="1" value="&quot;PARAMETER&quot;" />
          <attvalue for="2" value="&quot;The baud rate divisor is a register that divides the system clock to generate the SPI clock.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="4" />
        </attvalues>
      </node>
      <node id="90fbaa5b-dc56-415e-9da1-46dc1e5151c4" label="&quot;STATUS REGISTER&quot;">
        <attvalues>
          <attvalue for="0" value="26" />
          <attvalue for="1" value="&quot;PARAMETER&quot;" />
          <attvalue for="2" value="&quot;The status register is a read-only register that contains status flags.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="4" />
        </attvalues>
      </node>
      <node id="1677ebc7-a583-408e-bf40-ad3ad3f401eb" label="&quot;RECEIVE BUFFER&quot;">
        <attvalues>
          <attvalue for="0" value="27" />
          <attvalue for="1" value="&quot;MODULE&quot;" />
          <attvalue for="2" value="&quot;The receive buffer is a component of the SDC that stores received data.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="2" />
        </attvalues>
      </node>
      <node id="10e9be45-abd1-4623-a300-bb1482a8a87e" label="&quot;TRANSMIT BUFFER&quot;">
        <attvalues>
          <attvalue for="0" value="28" />
          <attvalue for="1" value="&quot;MODULE&quot;" />
          <attvalue for="2" value="&quot;The transmit buffer is a component of the SDC that stores data to be transmitted.&quot;" />
          <attvalue for="3" value="['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']" />
          <attvalue for="4" value="1" />
          <attvalue for="5" value="2" />
        </attvalues>
      </node>
      <node id="a930e1d1-3da3-4a55-9e12-b09fc7a0660c" label="&quot;SPI PROTOCOL&quot;">
        <attvalues>
          <attvalue for="0" value="29" />
          <attvalue for="1" value="&quot;PROTOCOL&quot;" />
          <attvalue for="2" value="&quot;The SPI protocol is used for communication with external slave devices.&quot;" />
