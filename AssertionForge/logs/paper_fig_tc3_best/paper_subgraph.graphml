  <graph edgedefault="undirected">
    <node id="&quot;SERIAL DATA CONTROLLER (SDC)&quot;">
      <data key="d0">67ef01a4-cdeb-43d9-9881-d9786262c752</data>
      <data key="d1">0</data>
      <data key="d2">"MODULE"</data>
      <data key="d3">"The Serial Data Controller (SDC) is a module that provides an APB slave interface and a SPI-compatible serial interface for communication with external slave devices."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">12</data>
    </node>
    <node id="&quot;APB INTERFACE&quot;">
      <data key="d0">aff1ceb1-8c84-4cac-8ee9-913ca5704dce</data>
      <data key="d1">1</data>
      <data key="d2">"INTERFACE"</data>
      <data key="d3">"The APB interface is used for host processor configuration."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">10</data>
    </node>
    <node id="&quot;SPI INTERFACE&quot;">
      <data key="d0">338983ca-f2c7-426d-bb85-97e213320911</data>
      <data key="d1">2</data>
      <data key="d2">"INTERFACE"</data>
      <data key="d3">"The SPI interface is used for communication with external slave devices."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">7</data>
    </node>
    <node id="&quot;SYSTEM CLOCK&quot;">
      <data key="d0">3dec1e15-cb67-4598-8d6d-f03795410a43</data>
      <data key="d1">3</data>
      <data key="d2">"CLOCK"</data>
      <data key="d3">"The system clock is the primary clock input for the SDC."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">3</data>
    </node>
    <node id="&quot;SYSTEM RESET&quot;">
      <data key="d0">c9f8655b-4f06-4df0-aba0-99edbe58b41b</data>
      <data key="d1">4</data>
      <data key="d2">"RESET"</data>
      <data key="d3">"The system reset is an asynchronous, active-low signal that clears all registers and deasserts the chip select when asserted low."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f'
 '1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">2</data>
      <data key="d6">4</data>
    </node>
    <node id="&quot;PERIPHERAL SELECT&quot;">
      <data key="d0">3bdbe4f2-9be5-45ec-94ed-6abc1932fc49</data>
      <data key="d1">5</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"The peripheral select signal is driven high by the APB master to select the SDC."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">1</data>
    </node>
    <node id="&quot;TRANSFER ENABLE&quot;">
      <data key="d0">deca1e63-ff7e-49fd-963d-58f90469b9b4</data>
      <data key="d1">6</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"The transfer enable signal marks the second cycle of an APB transfer."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">1</data>
    </node>
    <node id="&quot;WRITE ENABLE&quot;">
      <data key="d0">f75dd1cc-ff0e-4721-900e-92d32f72b38e</data>
      <data key="d1">7</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"The write enable signal is high for write and low for read operations."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">1</data>
    </node>
    <node id="&quot;REGISTER ADDRESS&quot;">
      <data key="d0">1b4da10d-adcb-4197-840b-0cf9b6332e01</data>
      <data key="d1">8</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"The register address signal is an 8-bit address bus that selects the target register."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">1</data>
    </node>
    <node id="&quot;WRITE DATA BUS&quot;">
      <data key="d0">d986e63c-7021-40fd-a242-83f70dd1a3f5</data>
      <data key="d1">9</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"The write data bus is a 32-bit data bus from the master to the SDC during writes."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">1</data>
    </node>
    <node id="&quot;READ DATA BUS&quot;">
      <data key="d0">fa4b8e9c-7465-4949-95b9-bfdea70ba1e3</data>
      <data key="d1">10</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"The read data bus is a 32-bit data bus from the SDC to the master during reads."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">1</data>
    </node>
    <node id="&quot;TRANSFER ACKNOWLEDGE&quot;">
      <data key="d0">016bd329-b71a-429e-b108-dba38fbd2e63</data>
      <data key="d1">11</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"The transfer acknowledge signal is asserted high by the SDC to complete the APB transaction."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">1</data>
    </node>
    <node id="&quot;SERIAL CLOCK&quot;">
      <data key="d0">ec4bd048-e455-44f5-8d58-3366a51e0184</data>
      <data key="d1">12</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"The serial clock signal is generated by the SDC and its frequency is set by the baud rate divisor."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">1</data>
    </node>
    <node id="&quot;MASTER DATA OUTPUT&quot;">
      <data key="d0">93f733c4-ec40-43f9-a711-c0d68dd4b5a4</data>
      <data key="d1">13</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"The master data output signal is the serial data output from the SDC to the external slave."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">1</data>
    </node>
    <node id="&quot;MASTER DATA INPUT&quot;">
      <data key="d0">e2e2e127-c015-449e-b082-06e4d63dff2b</data>
      <data key="d1">14</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"The master data input signal is the serial data input from the external slave to the SDC."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">1</data>
    </node>
    <node id="&quot;CHIP SELECT&quot;">
      <data key="d0">6ed3577e-de16-41d1-b4b9-cfb109d77f1d</data>
      <data key="d1">15</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"The chip select signal is an active-low output that is driven low at the start of a frame to address the external slave."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">1</data>
    </node>
    <node id="&quot;INTERRUPT REQUEST&quot;">
      <data key="d0">b0381e93-039c-4905-a43b-f6c262576f0f</data>
      <data key="d1">16</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"The interrupt request signal is asserted when transmission is complete or a parity error is detected."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">1</data>
    </node>
    <node id="&quot;TRANSMISSION COMPLETE&quot;">
      <data key="d0">2ee5ee69-6b74-49e6-ae6c-a7a9f9f60c58</data>
      <data key="d1">17</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"The transmission complete signal is pulsed for one clock cycle when the last bit of a frame has been shifted out."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">0</data>
    </node>
    <node id="&quot;TRANSMIT ACKNOWLEDGE&quot;">
      <data key="d0">d2df1a40-d564-4136-864d-f2525789c7a8</data>
      <data key="d1">18</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"The transmit acknowledge signal is set when the remote slave confirms receipt of the last transmitted byte."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">0</data>
    </node>
    <node id="&quot;FIFO EMPTY STATUS&quot;">
      <data key="d0">74edf1e8-b0bf-40fa-ba1d-18fe7eac7ba4</data>
      <data key="d1">19</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"The FIFO empty status signal is asserted when the transmit buffer has no pending data and is ready for a new frame."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">0</data>
    </node>
    <node id="&quot;DATA VALID&quot;">
      <data key="d0">609deb5d-01bc-4a09-8753-45eeaedaa027</data>
      <data key="d1">20</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"The data valid signal is asserted for one cycle when a new received byte is available in the receive buffer."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">0</data>
    </node>
    <node id="&quot;PARITY ERROR FLAG&quot;">
      <data key="d0">86202cdb-9133-4430-9364-7d4c07e7c35e</data>
      <data key="d1">21</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"The parity error flag signal is set and held when a parity mismatch is detected on the received byte."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">0</data>
    </node>
    <node id="&quot;RECEIVE BUFFER FULL&quot;">
      <data key="d0">621d9ab0-6a1a-4221-8012-c33898cec5f1</data>
      <data key="d1">22</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"The receive buffer full signal is an active-low flag that is deasserted when the receive buffer cannot accept additional bytes."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">0</data>
    </node>
    <node id="&quot;FLOW CONTROL ENABLE&quot;">
      <data key="d0">34b56916-3b24-4035-9a21-d04aef2f9117</data>
      <data key="d1">23</data>
      <data key="d2">"SIGNAL"</data>
      <data key="d3">"The flow control enable signal is set in the control register to activate CTS/RTS-style handshaking."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">0</data>
    </node>
    <node id="&quot;CONTROL REGISTER&quot;">
      <data key="d0">bf744a66-b0b0-47c3-88eb-df537ac6c421</data>
      <data key="d1">24</data>
      <data key="d2">"PARAMETER"</data>
      <data key="d3">"The control register is a register that contains mode and enable bits."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">5</data>
    </node>
    <node id="&quot;BAUD RATE DIVISOR&quot;">
      <data key="d0">d4bfcc4c-1e24-4d9f-9032-31165a750cd9</data>
      <data key="d1">25</data>
      <data key="d2">"PARAMETER"</data>
      <data key="d3">"The baud rate divisor is a register that divides the system clock to generate the SPI clock."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">4</data>
    </node>
    <node id="&quot;STATUS REGISTER&quot;">
      <data key="d0">90fbaa5b-dc56-415e-9da1-46dc1e5151c4</data>
      <data key="d1">26</data>
      <data key="d2">"PARAMETER"</data>
      <data key="d3">"The status register is a read-only register that contains status flags."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">4</data>
    </node>
    <node id="&quot;RECEIVE BUFFER&quot;">
      <data key="d0">1677ebc7-a583-408e-bf40-ad3ad3f401eb</data>
      <data key="d1">27</data>
      <data key="d2">"MODULE"</data>
      <data key="d3">"The receive buffer is a component of the SDC that stores received data."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">2</data>
    </node>
    <node id="&quot;TRANSMIT BUFFER&quot;">
      <data key="d0">10e9be45-abd1-4623-a300-bb1482a8a87e</data>
      <data key="d1">28</data>
      <data key="d2">"MODULE"</data>
      <data key="d3">"The transmit buffer is a component of the SDC that stores data to be transmitted."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">2</data>
    </node>
    <node id="&quot;SPI PROTOCOL&quot;">
      <data key="d0">a930e1d1-3da3-4a55-9e12-b09fc7a0660c</data>
      <data key="d1">29</data>
      <data key="d2">"PROTOCOL"</data>
      <data key="d3">"The SPI protocol is used for communication with external slave devices."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">3</data>
    </node>
    <node id="&quot;APB PROTOCOL&quot;">
      <data key="d0">0a7b7cf5-9773-4746-b57f-9ff3436f7ecf</data>
      <data key="d1">30</data>
      <data key="d2">"PROTOCOL"</data>
      <data key="d3">"The APB protocol is used for host processor configuration."</data>
      <data key="d4">['1ebec9d4116bf8cbf50f571b0ab39e17333c538abac0d28b63067bdab402d5970474677a6cee5ae03345e578579b1c858f90bcfd21be21f87c7bb8f66e408a5f']</data>
      <data key="d5">1</data>
      <data key="d6">2</data>
    </node>
    <node id="&quot;FLOW CONTROL&quot;">
      <data key="d0">23918916-cd67-481d-a933-9f6275514ca4</data>
      <data key="d1">31</data>
      <data key="d2">"PARAMETER"</data>
      <data key="d3">"The flow control is a parameter that determines whether CTS/RTS-style handshaking is enabled."</data>
